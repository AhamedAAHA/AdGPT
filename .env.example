# AdGPT Environment Variables
# Copy this file to .env.local and fill in your values

# OpenAI API Key (required for AI features)
OPENAI_API_KEY=sk-your-openai-api-key

# Supabase (required for persistence)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (for callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Speechmatics (optional — audio-to-script + word-synced captions)
SPEECHMATICS_API_KEY=your-speechmatics-api-key
# SPEECHMATICS_API_URL=https://asr.api.speechmatics.com/v2

# Pexels (optional — stock B-roll clips for Tier 3 video)
PEXELS_API_KEY=your-pexels-api-key

# Replicate (optional — AI image-to-video for proof beats)
REPLICATE_API_TOKEN=your-replicate-api-token
